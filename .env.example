# Server
PORT=3001
NODE_ENV=development

# Database path (optional, defaults to ./server/db/mnemonic.db)
DB_PATH=./server/db/mnemonic.db

# Log level: trace | debug | info | warn | error | fatal
# Defaults to debug in dev, info in production
LOG_LEVEL=debug

# Directory for SQLite backups (defaults to ../data/backups relative to server/)
BACKUP_DIR=./data/backups

# Anthropic API key for AI card generation (optional — feature disabled without it)
ANTHROPIC_API_KEY=
